export default async function handler(req, res) {

  const link = req.query.bypass

  if (!link) {
    return res.status(400).json({ error: "no link" })
  }

  const response = await fetch(
    `https://api-bypass-phi.vercel.app/api/bypass?bypass=${encodeURIComponent(link)}`,
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        key: "fqzzdx-136278150"
      })
    }
  )

  const data = await response.json()

  res.json(data)
}
